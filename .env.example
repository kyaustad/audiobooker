# App
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-me-to-a-long-random-string

# SQLite database file (persist this path in Docker)
DATABASE_PATH=/data/audiobooker.db

# qBittorrent Web UI (use your Unraid container hostname/IP)
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# Paths as seen inside this container — must match your volume mounts
QBITTORRENT_DOWNLOAD_PATH=/downloads
AUDIOBOOK_DEST_PATH=/audiobooks

# Optional: seed an admin on first startup
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me

# Set to false to disable open registration after the first user
ALLOW_REGISTRATION=true

# Background sync interval in milliseconds
SYNC_INTERVAL_MS=10000
