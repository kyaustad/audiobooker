# --- Host mapping ---
HOST_PORT=3000
# Persistent DB / app state (Unraid example: /mnt/user/appdata/audiobooker)
APPDATA_PATH=./data
# Must be the same completed-downloads share qBittorrent uses
TORRENT_DOWNLOADS_PATH=/mnt/user/downloads
# Audiobookshelf library root
AUDIOBOOK_LIBRARY_PATH=/mnt/user/audiobooks

# --- Container ---
# false for LAN HTTP; true only when the UI is served over HTTPS
COOKIE_SECURE=false
# Unraid typical share owner: 99:100 — ensure APPDATA_PATH is chown'd to match
PUID=0
PGID=0
