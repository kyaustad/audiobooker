# --- Host mapping ---
HOST_PORT=3000
# Persistent DB / app state (Unraid example: /mnt/user/appdata/audiobooker)
APPDATA_PATH=./data

# --- Container ---
# false for LAN HTTP; true only when the UI is served over HTTPS
COOKIE_SECURE=false
# Unraid typical share owner: 99:100 — ensure APPDATA_PATH is chown'd to match
PUID=0
PGID=0

# Mount downloads + library folders yourself in docker-compose / Unraid UI
# (any container paths you want). Assign them in Settings → Libraries.
